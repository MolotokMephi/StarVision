# StarVision Backend — Environment Variables

# OpenRouter API key for StarAI. Keep this file on the backend only.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Optional fallback provider (get at console.anthropic.com)
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated). Add the public origin of the
# deployed frontend here — never commit it to the repo. Defaults to
# localhost only if unset.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# StarAI chat rate limit per client IP per minute (set to 0 to disable).
CHAT_RATE_LIMIT_PER_MIN=20

# Set to 1 only when running behind a trusted reverse proxy that strips
# and rewrites the X-Forwarded-For header.
TRUST_FORWARDED_FOR=0
