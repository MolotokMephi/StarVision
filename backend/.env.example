# StarVision Backend — Environment Variables

# OpenRouter API key for StarAI. Keep this file on the backend only.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Optional fallback provider (get at console.anthropic.com)
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://78.17.40.155
